# turntable API credentials. Copy to .env (which is gitignored) and fill in.
# Register: Discogs https://www.discogs.com/settings/developers
#           Last.fm https://www.last.fm/api/account/create
#           Setlist.fm https://www.setlist.fm/settings/api
# MusicBrainz needs no key, only a descriptive User-Agent.

DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
DISCOGS_USERNAME=            # your Discogs username (for collection ingestion)

MUSICBRAINZ_USER_AGENT=turntable/0.1 (https://github.com/youruser)

LASTFM_API_KEY=
LASTFM_SHARED_SECRET=
LASTFM_USERNAME=             # the username you scrobble to

SETLISTFM_API_KEY=
