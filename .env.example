# Discogs — https://www.discogs.com/settings/developers
DISCOGS_TOKEN=
DISCOGS_USERNAME=

# Last.fm — https://www.last.fm/api/account/create
LASTFM_API_KEY=
LASTFM_USERNAME=

# MusicBrainz requires a descriptive UA string, not a key.
MUSICBRAINZ_USER_AGENT=turntable/0.1 (your-email@example.com)

# Setlist.fm — https://api.setlist.fm/docs/1.0/index.html
SETLISTFM_API_KEY=

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

TURNTABLE_DB_PATH=data/turntable.duckdb
